{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2017", "ES2018.AsyncIterable"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "baseUrl": "src",
    "paths": {
      "@config": ["config/index.ts"],
      "@database": ["database/index.ts"],
      "@controllers/*": ["controllers/*.ts"],
      "@dtos/*": ["dtos/*.ts"],
      "@exceptions/*": ["exceptions/*.ts"],
      "@interfaces/*": ["interfaces/*.ts"],
      "@middlewares/*": ["middlewares/*.ts"],
      "@models/*": ["models/*.ts"],
      "@routes/*": ["routes/*.ts"],
      "@services/*": ["services/*.ts"],
      "@utils/*": ["utils/*.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.{spec,test}.ts"]
}
